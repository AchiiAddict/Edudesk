{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ],
        "RateLimiterPolicy": "fixed-policy"
      },
      "support-route": {
        "ClusterId": "support-cluster",
        "Match": {
          "Path": "/support/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ],
        "RateLimiterPolicy": "fixed-policy"
      },
      "learning-route": {
        "ClusterId": "learning-cluster",
        "Match": {
          "Path": "/learning/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ],
        "RateLimiterPolicy": "fixed-policy"
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://identity-api:8080" }
        }
      },
      "support-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://support-api:8080" }
        }
      },
      "learning-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://learning-api:8080" }
        }
      }
    }
  }
}